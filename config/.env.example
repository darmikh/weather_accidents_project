# НАСТРОЙКИ ПРОЕКТА: Влияние погоды на ДТП

# Supabase (облачная база данных)
# Получите на: https://supabase.com → New Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-public-key-here

# Яндекс Геокодер API (для получения координат)
# Получите на: https://developer.tech.yandex.ru/services/
YANDEX_GEOCODER_API_KEY=your_yandex_key_here

# Настройки приложения
LOG_LEVEL=INFO                    # DEBUG, INFO, WARNING, ERROR
MAX_CITIES_TO_PROCESS=50          # Сколько городов обрабатывать
REQUEST_DELAY=1.5                 # Задержка между API запросами (сек)

# Open-Meteo API (будет позже)
OPEN_METEO_API_KEY=

# ГИБДД API (будет позже)
GIBDD_API_KEY=